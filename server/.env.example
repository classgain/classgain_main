PORT=5000
MONGO_URI=mongodb+srv://classgainown:1234@classgain-technology.zbdxbhi.mongodb.net/?appName=classgain-technology
# Optional fallback when the local DNS server refuses MongoDB SRV lookups
MONGO_DNS_SERVERS=8.8.8.8,1.1.1.1
MONGO_RETRY_DELAY_MS=10000
# Set this to a comma-separated list of the frontend origins that are live.
# The individual variables below remain supported and may be used instead.
FRONTEND_URLS=https://classgain.com,https://www.classgain.com,https://studeup.com,https://www.studeup.com,https://classgain-admin.com
CLIENT_URL=https://classgain.com
SELLER_URL=https://studeup.com
ADMIN_URL=https://classgain-admin.com
JWT_SECRET=replace-with-at-least-32-random-characters
ADMIN_API_KEY=replace-with-a-separate-strong-random-key
NODE_ENV=production

# Optional production tuning
JSON_BODY_LIMIT=10mb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20
UPLOAD_DIR=./uploads
