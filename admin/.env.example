# Keep API requests same-origin. Vite proxies /api in development and Vercel
# rewrites it to the Render backend in production, avoiding browser CORS issues.
VITE_API_URL=/api
VITE_DEV_API_TARGET=http://127.0.0.1:5000
VITE_ADMIN_KEY_STORAGE_NAME=what-next-admin-key
VITE_CLIENT_URL=https://your-client.vercel.app
VITE_SELLER_URL=https://your-seller.vercel.app
